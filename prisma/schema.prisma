generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid()) @map("id")
  email        String   @unique @map("email")
  passwordHash String   @map("password_hash")
  role         String   @default("admin") @map("role")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Page {
  id        String   @id @default(cuid()) @map("id")
  slug      String   @unique @map("slug")
  title     String   @map("title")
  subtitle  String   @map("subtitle")
  heroImage String   @map("hero_image")
  heroVideo String   @default("") @map("hero_video")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model GalleryItem {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  tier        String   @default("") @map("tier")
  description String   @default("") @map("description")
  imageUrl    String   @default("") @map("image_url")
  videoUrl    String   @default("") @map("video_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("gallery")
}

model Solution {
  id          String   @id @default(cuid()) @map("id")
  slug        String   @unique @map("slug")
  title       String   @map("title")
  description String   @default("") @map("description")
  price       Decimal  @db.Decimal(10, 2) @map("price")
  imageUrl    String   @default("") @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("solutions")
}

model SiteContentOverride {
  id        String   @id @default(cuid()) @map("id")
  locale    String   @unique @map("locale")
  data      Json     @map("data")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_content_overrides")
}

model PricingSettings {
  id              String   @id @default("default") @map("id")
  discountPercent Int      @default(0) @map("discount_percent")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pricing_settings")
}
